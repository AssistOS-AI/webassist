#!/usr/bin/env bash

set -euo pipefail
trap 'printf "\n"; exit 130' INT

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WEBCLI_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
INDEX_PATH="${WEBCLI_ROOT}/src/index.mjs"

MODE="interactive"
SESSION_ID=""
JSON_OUTPUT=false
DATA_DIR=""
AGENT_ROOT_OVERRIDE=""
POSITIONAL=()

print_usage() {
    cat <<'EOF'
Usage:
  web-cli "message"
  web-cli -mcp "message"

Options:
  -mcp                     Run a single request and exit
  --session-id <id>        Reuse a specific session id
  --json                   Print JSON output from runtime
  --data-dir <dir>         Override data directory
  --agent-root <dir>       Override agent root directory
  -h, --help               Show this help
EOF
}

generate_session_id() {
    local timestamp random_part
    timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
    random_part="${RANDOM}${RANDOM}"
    printf 'session-%s-%s' "$timestamp" "$random_part"
}

run_turn() {
    local message="$1"
    local -a cmd

    cmd=(node "$INDEX_PATH" --session-id "$SESSION_ID" --message "$message")

    if [[ "$JSON_OUTPUT" == true ]]; then
        cmd+=(--json)
    fi
    if [[ -n "$DATA_DIR" ]]; then
        cmd+=(--data-dir "$DATA_DIR")
    fi
    if [[ -n "$AGENT_ROOT_OVERRIDE" ]]; then
        cmd+=(--agent-root "$AGENT_ROOT_OVERRIDE")
    fi

    "${cmd[@]}"
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -mcp)
            MODE="mcp"
            shift
            ;;
        --session-id)
            if [[ $# -lt 2 ]]; then
                echo "Missing value for --session-id" >&2
                exit 1
            fi
            SESSION_ID="$2"
            shift 2
            ;;
        --session-id=*)
            SESSION_ID="${1#*=}"
            shift
            ;;
        --json)
            JSON_OUTPUT=true
            shift
            ;;
        --data-dir)
            if [[ $# -lt 2 ]]; then
                echo "Missing value for --data-dir" >&2
                exit 1
            fi
            DATA_DIR="$2"
            shift 2
            ;;
        --data-dir=*)
            DATA_DIR="${1#*=}"
            shift
            ;;
        --agent-root)
            if [[ $# -lt 2 ]]; then
                echo "Missing value for --agent-root" >&2
                exit 1
            fi
            AGENT_ROOT_OVERRIDE="$2"
            shift 2
            ;;
        --agent-root=*)
            AGENT_ROOT_OVERRIDE="${1#*=}"
            shift
            ;;
        -h|--help)
            print_usage
            exit 0
            ;;
        --)
            shift
            while [[ $# -gt 0 ]]; do
                POSITIONAL+=("$1")
                shift
            done
            ;;
        -*)
            echo "Unknown option: $1" >&2
            print_usage >&2
            exit 1
            ;;
        *)
            POSITIONAL+=("$1")
            shift
            ;;
    esac
done

if [[ -z "$SESSION_ID" ]]; then
    SESSION_ID="$(generate_session_id)"
fi

MESSAGE="${POSITIONAL[*]}"

if [[ "$MODE" == "mcp" ]]; then
    if [[ -z "$MESSAGE" && ! -t 0 ]]; then
        MESSAGE="$(< /dev/stdin)"
    fi

    if [[ -z "$MESSAGE" ]]; then
        echo "MCP mode requires a message." >&2
        print_usage >&2
        exit 1
    fi

    run_turn "$MESSAGE"
    exit 0
fi

if [[ "$JSON_OUTPUT" != true ]]; then
    printf 'Session ID: %s\n' "$SESSION_ID"
    printf 'Type exit to leave\n'
fi

if [[ -n "$MESSAGE" ]]; then
    run_turn "$MESSAGE"
fi

while true; do
    if ! IFS= read -r -p "you> " line; then
        printf '\n'
        break
    fi

    case "$line" in
        '' )
            continue
            ;;
        exit|quit|:q)
            break
            ;;
    esac

    run_turn "$line"
done
